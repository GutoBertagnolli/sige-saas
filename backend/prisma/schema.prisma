generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Shift {
  MATUTINO
  VESPERTINO
  NOTURNO
  INTEGRAL
}

enum EducationStage {
  CEIM
  ANOS_INICIAIS
  ANOS_FINAIS
  ENSINO_MEDIO
  ADMINISTRATIVO
}

enum SlotType {
  CLASS
  BREAK
  LUNCH
  ACTIVITY
  REST
  ADMINISTRATIVE
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AbsenceStatus {
  OPEN
  SUBSTITUTIONS_GENERATED
  CLOSED
  CANCELLED
}

enum SubstitutionStatus {
  PENDING_DIRECTOR
  SENT_TO_TEACHER
  ACCEPTED
  DECLINED
  CANCELLED
}

enum EmployeeRoleType {
  PROFESSOR
  AUXILIAR
  ORIENTADOR
  DIRETOR
  COORDENADOR
  SECRETARIA
  SERVICOS_GERAIS
}

model Tenant {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String   @default("#1E3A8A")
  secondaryColor String   @default("#DC2626")
  domain         String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users           User[]
  roles           Role[]
  schools         School[]
  subjects        Subject[]
  functions       EmployeeFunction[]
  employees       Employee[]
  templates       SchoolTimeTemplate[]
  classes         Class[]
  announcements   Announcement[]
  weeklySchedules EmployeeWeeklySchedule[]
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  email        String
  phone        String?
  passwordHash String
  roleId       String?
  role         Role?     @relation(fields: [roleId], references: [id])
  active       Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AuditLog[]

  @@unique([tenantId, email])
}

model Role {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  active      Boolean          @default(true)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model School {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  type      String   @default("ESCOLA")
  address   String?
  phone     String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates       SchoolTimeTemplate[]
  classes         Class[]
  employees       Employee[]
  weeklySchedules EmployeeWeeklySchedule[]
}

model Subject {
  id       String  @id @default(uuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  name     String
  color    String?
  active   Boolean @default(true)

  schedules ClassSchedule[]
}

model EmployeeFunction {
  id              String  @id @default(uuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id])
  name            String
  requiresSubject Boolean @default(false)
  active          Boolean @default(true)

  assignments EmployeeAssignment[]
}

model Employee {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  schoolId  String?
  school    School?          @relation(fields: [schoolId], references: [id])
  roleType  EmployeeRoleType @default(PROFESSOR)
  name      String
  cpf       String?
  birthDate DateTime?
  email     String?
  phone     String?
  photoUrl  String?
  active    Boolean          @default(true)

  assignments     EmployeeAssignment[]
  schedules       ClassSchedule[]          @relation("TeacherSchedule")
  absences        Absence[]
  weeklySchedules EmployeeWeeklySchedule[]
}

model EmployeeAssignment {
  id            String           @id @default(uuid())
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id])
  schoolId      String
  functionId    String
  function      EmployeeFunction @relation(fields: [functionId], references: [id])
  subjectId     String?
  weeklyMinutes Int              @default(0)
  active        Boolean          @default(true)
}

model SchoolTimeTemplate {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  schoolId       String
  school         School         @relation(fields: [schoolId], references: [id])
  name           String
  shift          Shift
  educationStage EducationStage
  active         Boolean        @default(true)

  slots   SchoolTimeSlot[]
  classes Class[]
}

model SchoolTimeSlot {
  id                   String                   @id @default(uuid())
  templateId           String
  template             SchoolTimeTemplate       @relation(fields: [templateId], references: [id])
  slotOrder            Int
  startTime            String
  endTime              String
  slotType             SlotType
  requiresSubstitution Boolean                  @default(true)
  isTeachingTime       Boolean                  @default(true)
  substitutions        Substitution[]
  weeklySchedules      EmployeeWeeklySchedule[]
  schedules            ClassSchedule[]

  @@unique([templateId, slotOrder])
}

model Class {
  id             String             @id @default(uuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  schoolId       String
  school         School             @relation(fields: [schoolId], references: [id])
  academicYear   Int
  name           String
  shift          Shift
  educationStage EducationStage
  templateId     String
  template       SchoolTimeTemplate @relation(fields: [templateId], references: [id])
  active         Boolean            @default(true)

  weeklySchedules EmployeeWeeklySchedule[]
  schedules       ClassSchedule[]
}

model ClassSchedule {
  id         String         @id @default(uuid())
  tenantId   String
  classId    String
  class      Class          @relation(fields: [classId], references: [id])
  weekday    Weekday
  timeSlotId String
  timeSlot   SchoolTimeSlot @relation(fields: [timeSlotId], references: [id])
  subjectId  String?
  subject    Subject?       @relation(fields: [subjectId], references: [id])
  teacherId  String?
  teacher    Employee?      @relation("TeacherSchedule", fields: [teacherId], references: [id])
  room       String?
  notes      String?
  isActive   Boolean        @default(true)

  substitutions Substitution[]

  @@unique([classId, weekday, timeSlotId])
}

model Absence {
  id          String        @id @default(uuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  type        String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  documentUrl String?
  status      AbsenceStatus @default(OPEN)
  createdBy   String?
  createdAt   DateTime      @default(now())

  substitutions Substitution[]
}

model Substitution {
  id String @id @default(uuid())

  absenceId String
  absence   Absence @relation(fields: [absenceId], references: [id])

  classScheduleId String?
  classSchedule   ClassSchedule? @relation(fields: [classScheduleId], references: [id])

  timeSlotId String?
  timeSlot   SchoolTimeSlot? @relation(fields: [timeSlotId], references: [id])

  weekday Weekday?

  originalTeacherId   String
  substituteTeacherId String?

  score  Int                @default(0)
  status SubstitutionStatus @default(PENDING_DIRECTOR)

  approvedBy String?
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  scoreDetails SubstitutionScore[]

  @@index([absenceId])
  @@index([originalTeacherId])
  @@index([substituteTeacherId])
  @@index([timeSlotId])
}

model SubstitutionScore {
  id             String       @id @default(uuid())
  substitutionId String
  substitution   Substitution @relation(fields: [substitutionId], references: [id])
  rule           String
  points         Int
  description    String?
}

model Announcement {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  schoolId       String?
  createdBy      String
  title          String
  message        String
  imageUrl       String?
  visibilityType String    @default("ALL")
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())

  targets AnnouncementTarget[]
}

model AnnouncementTarget {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  roleId         String?
  schoolId       String?
  employeeId     String?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  entity    String
  entityId  String?
  action    String
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model EmployeeWeeklySchedule {
  id String @id @default(uuid())

  tenantId   String
  employeeId String
  schoolId   String
  classId    String?
  timeSlotId String

  weekday Weekday

  type         String
  subject      String?
  functionName String?

  requiresSubstitution Boolean @default(true)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  employee Employee       @relation(fields: [employeeId], references: [id])
  school   School         @relation(fields: [schoolId], references: [id])
  class    Class?         @relation(fields: [classId], references: [id])
  timeSlot SchoolTimeSlot @relation(fields: [timeSlotId], references: [id])

  @@index([employeeId, weekday])
  @@index([schoolId])
}
